# Kick Bot Configuration
# Copy this file to .env and modify the values

# Required: Kick channel name or full URL
# Examples:
#   KICK_CHANNEL=xqc
#   KICK_CHANNEL=https://kick.com/xqc
KICK_CHANNEL=your_channel_name

# Optional: Number of viewers to send (default: 100)
KICK_VIEWERS=500

# Optional: Log level (debug, info, warn, error)
LOG_LEVEL=info
